generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Paciente {
  id              Int      @id @default(autoincrement())
  nome            String
  dataNascimento  DateTime
  carteirinha     String
  cpf             String   @unique
  createdAt       DateTime @default(now())
}